<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RHRI — Reproductive Health Research Institute</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --navy-900: #0F1B33;
  --navy-800: #162444;
  --navy-700: #1E2D52;
  --purple-700: #4A2D7A;
  --purple-600: #6B3FA0;
  --purple-500: #8B6BB5;
  --purple-400: #9E85C4;
  --purple-300: #B8A3D6;
  --purple-200: #D4C7E8;
  --purple-100: #EDE7F5;
  --purple-50: #F7F3FC;
  --white: #FFFFFF;
  --off-white: #F8F7FB;
  --gray-100: #F0EEF4;
  --gray-200: #E0DDE8;
  --gray-300: #C8C4D2;
  --gray-400: #8E8A9A;
  --gray-600: #5A5668;
  --gray-800: #2E2A3A;
  --font-display: 'Cormorant Garamond', Georgia, serif;
  --font-body: 'Outfit', system-ui, sans-serif;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body { font-family: var(--font-body); color: var(--gray-800); background: var(--white); overflow-x: hidden; line-height: 1.7; font-weight: 300; }
.page { display: none; min-height: 100vh; }
.page.active { display: block; }

/* NAV */
nav { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: rgba(255,255,255,0.92); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid rgba(15,27,51,0.06); transition: all 0.4s ease; }
nav.scrolled { background: rgba(255,255,255,0.97); box-shadow: 0 4px 24px rgba(15,27,51,0.06); }
.nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 40px; display: flex; align-items: center; justify-content: space-between; height: 72px; }
.logo { display: flex; align-items: center; gap: 14px; cursor: pointer; text-decoration: none; }
.logo-mark { width: 44px; height: 44px; flex-shrink: 0; }
.logo-mark svg { width: 100%; height: 100%; }
.logo-text { display: flex; flex-direction: column; line-height: 1.1; }
.logo-text .name { font-family: var(--font-display); font-size: 16px; font-weight: 600; color: var(--navy-800); letter-spacing: 0.5px; }
.logo-text .full { font-size: 9px; color: var(--purple-500); letter-spacing: 1.8px; text-transform: uppercase; font-weight: 500; margin-top: 2px; }
.nav-links { display: flex; gap: 4px; align-items: center; }
.nav-links a { color: var(--gray-600); text-decoration: none; font-size: 13.5px; font-weight: 400; padding: 8px 16px; border-radius: 8px; transition: all 0.25s ease; cursor: pointer; }
.nav-links a:hover { color: var(--navy-800); background: rgba(0,0,0,0.03); }
.nav-links a.active { color: var(--purple-600); font-weight: 500; }
.nav-links .cta-btn { background: var(--navy-800); color: #fff !important; padding: 9px 24px; border-radius: 8px; font-weight: 500; }
.nav-links .cta-btn:hover { background: var(--navy-900); transform: translateY(-1px); box-shadow: 0 4px 16px rgba(15,27,51,0.15); }
.mobile-toggle { display: none; background: none; border: none; cursor: pointer; padding: 8px; }
.mobile-toggle span { display: block; width: 22px; height: 2px; background: var(--navy-800); margin: 5px 0; }

/* HERO */
.hero { min-height: 100vh; background: var(--white); display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; padding: 120px 40px 80px; }
.hero::before { content: ''; position: absolute; top: -200px; right: -200px; width: 700px; height: 700px; background: radial-gradient(circle, var(--purple-50) 0%, transparent 70%); border-radius: 50%; }
.hero::after { content: ''; position: absolute; bottom: -300px; left: -150px; width: 500px; height: 500px; background: radial-gradient(circle, rgba(15,27,51,0.02) 0%, transparent 70%); border-radius: 50%; }
.hero-content { max-width: 780px; text-align: center; position: relative; z-index: 2; }
.hero-logo { width: 100px; height: 100px; margin: 0 auto 36px; animation: fadeInUp 0.7s ease both; }
.hero-logo svg { width: 100%; height: 100%; }
.hero-badge { display: inline-flex; align-items: center; gap: 8px; background: var(--purple-50); border: 1px solid var(--purple-100); padding: 7px 20px; border-radius: 100px; font-size: 10.5px; color: var(--purple-600); letter-spacing: 2.5px; text-transform: uppercase; font-weight: 600; margin-bottom: 32px; animation: fadeInUp 0.7s ease 0.1s both; }
.hero h1 { font-family: var(--font-display); font-size: clamp(2.8rem, 5.5vw, 4.4rem); font-weight: 500; color: var(--navy-800); line-height: 1.12; margin-bottom: 24px; animation: fadeInUp 0.7s ease 0.2s both; }
.hero h1 em { font-style: italic; color: var(--purple-600); }
.hero-sub { font-size: clamp(1rem, 1.6vw, 1.15rem); color: var(--gray-400); max-width: 560px; margin: 0 auto 40px; line-height: 1.85; font-weight: 300; animation: fadeInUp 0.7s ease 0.3s both; }
.hero-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; animation: fadeInUp 0.7s ease 0.4s both; }

/* BUTTONS */
.btn-primary { background: var(--navy-800); color: #fff; padding: 14px 32px; border-radius: 10px; text-decoration: none; font-weight: 500; font-size: 14px; transition: all 0.25s ease; border: none; cursor: pointer; font-family: var(--font-body); }
.btn-primary:hover { background: var(--navy-900); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(15,27,51,0.15); }
.btn-outline { background: transparent; border: 1.5px solid var(--gray-200); color: var(--gray-600); padding: 13px 32px; border-radius: 10px; text-decoration: none; font-weight: 400; font-size: 14px; transition: all 0.25s ease; cursor: pointer; font-family: var(--font-body); }
.btn-outline:hover { border-color: var(--purple-300); color: var(--purple-600); background: var(--purple-50); }
.btn-purple { background: var(--purple-600); color: #fff; padding: 14px 32px; border-radius: 10px; text-decoration: none; font-weight: 500; font-size: 14px; transition: all 0.25s ease; border: none; cursor: pointer; font-family: var(--font-body); }
.btn-purple:hover { background: var(--purple-700); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(107,63,160,0.2); }
@keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

/* ESSENCE */
.essence-bar { padding: 40px; text-align: center; background: var(--off-white); border-top: 1px solid var(--gray-100); border-bottom: 1px solid var(--gray-100); }
.essence-bar p { font-family: var(--font-display); font-size: 1.35rem; font-style: italic; color: var(--purple-600); font-weight: 500; }

/* SECTIONS */
.section { padding: 100px 40px; }
.section-white { background: var(--white); }
.section-off { background: var(--off-white); }
.section-navy { background: var(--navy-800); color: #fff; }
.container { max-width: 1100px; margin: 0 auto; }
.section-label { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--purple-600); font-weight: 600; margin-bottom: 14px; }
.section-navy .section-label { color: var(--purple-300); }
.section-title { font-family: var(--font-display); font-size: clamp(2rem, 3.5vw, 2.8rem); font-weight: 500; line-height: 1.2; margin-bottom: 18px; color: var(--navy-800); }
.section-navy .section-title { color: #fff; }
.section-subtitle { font-size: 1.05rem; color: var(--gray-400); max-width: 600px; line-height: 1.8; font-weight: 300; }
.section-navy .section-subtitle { color: rgba(255,255,255,0.55); }

/* FRAMEWORK */
.framework-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 56px; }
.pillar-card { background: var(--white); border: 1px solid var(--gray-100); border-radius: 16px; padding: 32px 24px; transition: all 0.35s ease; position: relative; overflow: hidden; }
.section-off .pillar-card { background: var(--white); }
.pillar-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--navy-700), var(--purple-600)); transform: scaleX(0); transform-origin: left; transition: transform 0.35s ease; }
.pillar-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(15,27,51,0.07); border-color: var(--purple-100); }
.pillar-card:hover::before { transform: scaleX(1); }
.pillar-num { font-family: var(--font-display); font-size: 2.4rem; font-weight: 700; color: var(--purple-200); line-height: 1; margin-bottom: 14px; }
.pillar-card h3 { font-family: var(--font-display); font-size: 1.25rem; font-weight: 600; color: var(--navy-800); margin-bottom: 10px; }
.pillar-card p { font-size: 0.86rem; color: var(--gray-400); line-height: 1.8; font-weight: 300; }

/* AUDIENCE */
.audience-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 56px; }
.audience-card { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 36px 30px; transition: all 0.3s ease; }
.audience-card:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.18); transform: translateY(-2px); }
.audience-icon { width: 44px; height: 44px; background: rgba(107,63,160,0.2); border-radius: 11px; display: flex; align-items: center; justify-content: center; margin-bottom: 18px; font-size: 18px; }
.audience-card h3 { font-family: var(--font-display); font-size: 1.25rem; font-weight: 600; color: #fff; margin-bottom: 8px; }
.audience-card p { font-size: 0.9rem; color: rgba(255,255,255,0.55); line-height: 1.8; font-weight: 300; }

/* STRATEGIC PILLARS */
.strat-pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 56px; }
.strat-card { background: var(--white); border: 1px solid var(--gray-100); border-radius: 16px; padding: 36px 28px; text-align: center; transition: all 0.35s ease; }
.strat-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(15,27,51,0.06); }
.strat-icon { width: 56px; height: 56px; margin: 0 auto 20px; background: var(--purple-50); border: 1px solid var(--purple-100); border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 24px; }
.strat-card h3 { font-family: var(--font-display); font-size: 1.25rem; font-weight: 600; color: var(--navy-800); margin-bottom: 10px; }
.strat-card p { font-size: 0.86rem; color: var(--gray-400); line-height: 1.8; font-weight: 300; }

/* TIMELINE */
.timeline { margin-top: 56px; position: relative; padding-left: 40px; }
.timeline::before { content: ''; position: absolute; left: 7px; top: 8px; bottom: 8px; width: 2px; background: linear-gradient(to bottom, var(--purple-300), var(--gray-200)); }
.timeline-item { position: relative; margin-bottom: 44px; }
.timeline-item:last-child { margin-bottom: 0; }
.timeline-item::before { content: ''; position: absolute; left: -40px; top: 8px; width: 16px; height: 16px; background: var(--off-white); border: 2.5px solid var(--purple-500); border-radius: 50%; }
.timeline-year { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--purple-500); font-weight: 600; margin-bottom: 6px; }
.timeline-item h3 { font-family: var(--font-display); font-size: 1.35rem; font-weight: 600; color: var(--navy-800); margin-bottom: 8px; }
.timeline-item p { color: var(--gray-400); font-size: 0.9rem; line-height: 1.85; font-weight: 300; max-width: 540px; }

/* CTA */
.cta-section { text-align: center; background: var(--navy-800); padding: 88px 40px; position: relative; overflow: hidden; }
.cta-section::before { content: ''; position: absolute; top: -50%; left: 50%; transform: translateX(-50%); width: 600px; height: 600px; background: radial-gradient(circle, rgba(107,63,160,0.1) 0%, transparent 60%); border-radius: 50%; }
.cta-section .container { position: relative; z-index: 2; }
.cta-section h2 { font-family: var(--font-display); font-size: clamp(2rem, 3.5vw, 2.8rem); color: #fff; font-weight: 500; margin-bottom: 16px; }
.cta-section h2 em { font-style: italic; color: var(--purple-300); }
.cta-section p { color: rgba(255,255,255,0.5); max-width: 480px; margin: 0 auto 32px; font-weight: 300; }

/* FOOTER */
footer { background: var(--white); border-top: 1px solid var(--gray-100); padding: 56px 40px 28px; }
.footer-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; }
.footer-brand .footer-logo-wrap { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
.footer-brand .footer-logo-wrap svg { width: 32px; height: 32px; flex-shrink: 0; }
.footer-brand .footer-logo-wrap span { font-family: var(--font-display); font-size: 14px; font-weight: 600; color: var(--navy-800); }
.footer-brand p { color: var(--gray-400); font-size: 0.84rem; line-height: 1.7; max-width: 260px; font-weight: 300; }
.footer-col h4 { color: var(--navy-800); font-size: 11px; letter-spacing: 2px; text-transform: uppercase; font-weight: 600; margin-bottom: 16px; }
.footer-col a { display: block; color: var(--gray-400); text-decoration: none; font-size: 0.84rem; margin-bottom: 9px; transition: color 0.2s; font-weight: 300; cursor: pointer; }
.footer-col a:hover { color: var(--purple-600); }
.footer-bottom { max-width: 1100px; margin: 32px auto 0; padding-top: 20px; border-top: 1px solid var(--gray-100); display: flex; justify-content: space-between; align-items: center; }
.footer-bottom p { color: var(--gray-300); font-size: 0.76rem; font-weight: 300; }

/* ABOUT */
.about-hero { min-height: 44vh; background: var(--white); display: flex; align-items: center; padding: 140px 40px 60px; position: relative; border-bottom: 1px solid var(--gray-100); }
.about-hero::before { content: ''; position: absolute; top: -200px; right: -100px; width: 500px; height: 500px; background: radial-gradient(circle, var(--purple-50) 0%, transparent 70%); border-radius: 50%; }
.about-hero .container { position: relative; z-index: 2; }
.about-hero h1 { font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 3.6rem); color: var(--navy-800); font-weight: 500; margin-bottom: 16px; }
.about-hero p { font-size: 1.05rem; color: var(--gray-400); max-width: 560px; font-weight: 300; line-height: 1.85; }
.about-content { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; margin-top: 56px; align-items: start; }
.about-block { margin-bottom: 40px; }
.about-block h3 { font-family: var(--font-display); font-size: 1.35rem; font-weight: 600; color: var(--navy-800); margin-bottom: 12px; }
.about-block p { color: var(--gray-400); font-size: 0.93rem; line-height: 1.9; font-weight: 300; }
.placeholder { background: var(--off-white); border: 2px dashed var(--gray-200); border-radius: 12px; padding: 28px; color: var(--gray-400) !important; font-style: italic; font-size: 0.93rem; line-height: 1.9; font-weight: 300; }
.values-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-top: 20px; }
.value-item { background: var(--white); border: 1px solid var(--gray-100); border-radius: 12px; padding: 22px 24px; transition: all 0.25s ease; }
.value-item:hover { border-color: var(--purple-200); box-shadow: 0 4px 16px rgba(15,27,51,0.03); }
.value-item h4 { font-family: var(--font-display); font-size: 1.05rem; font-weight: 600; color: var(--navy-800); margin-bottom: 5px; }
.value-item p { font-size: 0.82rem; color: var(--gray-400); line-height: 1.7; font-weight: 300; }
.team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 36px; }
.team-card { text-align: center; padding: 32px 20px; border: 1px solid var(--gray-100); border-radius: 16px; background: var(--white); transition: all 0.3s ease; }
.team-card:hover { box-shadow: 0 8px 24px rgba(15,27,51,0.05); }
.team-avatar { width: 80px; height: 80px; background: linear-gradient(135deg, var(--purple-50), var(--gray-100)); border-radius: 50%; margin: 0 auto 14px; display: flex; align-items: center; justify-content: center; font-size: 26px; color: var(--purple-400); }
.team-card h4 { font-family: var(--font-display); font-size: 1.1rem; font-weight: 600; color: var(--navy-800); margin-bottom: 3px; }
.team-card .role { font-size: 0.8rem; color: var(--purple-500); font-weight: 400; margin-bottom: 8px; }
.team-card p { font-size: 0.8rem; color: var(--gray-400); line-height: 1.7; font-weight: 300; font-style: italic; }

/* INNOVATION VERTICALS */
.innovation-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 56px; }
.innovation-card { background: var(--white); border: 1px solid var(--gray-100); border-radius: 16px; padding: 36px 30px; transition: all 0.35s ease; position: relative; overflow: hidden; }
.innovation-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--navy-700), var(--purple-600)); transform: scaleX(0); transform-origin: left; transition: transform 0.35s ease; }
.innovation-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(15,27,51,0.07); border-color: var(--purple-100); }
.innovation-card:hover::before { transform: scaleX(1); }
.innovation-icon { width: 52px; height: 52px; background: var(--purple-50); border: 1px solid var(--purple-100); border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 18px; }
.innovation-card h3 { font-family: var(--font-display); font-size: 1.3rem; font-weight: 600; color: var(--navy-800); margin-bottom: 10px; }
.innovation-card p { font-size: 0.88rem; color: var(--gray-400); line-height: 1.8; font-weight: 300; margin-bottom: 14px; }
.innovation-examples { font-size: 0.82rem; color: var(--purple-500); font-weight: 400; line-height: 1.7; }
.innovation-examples strong { font-weight: 500; color: var(--gray-600); }

/* FRAMEWORK DETAIL */
.framework-detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; margin-top: 56px; align-items: start; }
.framework-detail-text h3 { font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; color: var(--navy-800); margin-bottom: 14px; }
.framework-detail-text p { color: var(--gray-400); line-height: 1.9; font-weight: 300; font-size: 0.95rem; margin-bottom: 20px; }
.framework-detail-list { list-style: none; padding: 0; }
.framework-detail-list li { padding: 18px 22px; border: 1px solid var(--gray-100); border-radius: 12px; margin-bottom: 12px; transition: all 0.25s ease; }
.framework-detail-list li:hover { border-color: var(--purple-200); box-shadow: 0 4px 16px rgba(15,27,51,0.03); }
.framework-detail-list li strong { display: block; font-family: var(--font-display); font-size: 1.05rem; font-weight: 600; color: var(--navy-800); margin-bottom: 4px; }
.framework-detail-list li span { font-size: 0.85rem; color: var(--gray-400); line-height: 1.7; font-weight: 300; }

/* OPERATING MODEL */
.model-features { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 56px; }
.model-feature { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 28px 24px; transition: all 0.3s ease; }
.model-feature:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.18); }
.model-feature h4 { font-family: var(--font-display); font-size: 1.1rem; font-weight: 600; color: #fff; margin-bottom: 8px; }
.model-feature p { font-size: 0.88rem; color: rgba(255,255,255,0.55); line-height: 1.8; font-weight: 300; }

/* CONTACT MODAL */
.modal-overlay { display: none; position: fixed; inset: 0; z-index: 2000; background: rgba(15,27,51,0.45); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); align-items: center; justify-content: center; padding: 20px; }
.modal-overlay.active { display: flex; animation: modalFade 0.25s ease; }
@keyframes modalFade { from { opacity: 0; } to { opacity: 1; } }
.modal { background: var(--white); border-radius: 20px; max-width: 540px; width: 100%; max-height: 90vh; overflow-y: auto; box-shadow: 0 24px 80px rgba(15,27,51,0.2); position: relative; animation: modalSlide 0.35s cubic-bezier(0.16,1,0.3,1); }
@keyframes modalSlide { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
.modal-header { padding: 36px 36px 0; }
.modal-header h2 { font-family: var(--font-display); font-size: 1.8rem; font-weight: 600; color: var(--navy-800); margin-bottom: 6px; }
.modal-header p { font-size: 0.9rem; color: var(--gray-400); font-weight: 300; line-height: 1.6; }
.modal-close { position: absolute; top: 20px; right: 20px; width: 36px; height: 36px; border: none; background: var(--gray-100); border-radius: 10px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 18px; color: var(--gray-600); transition: all 0.2s ease; line-height: 1; }
.modal-close:hover { background: var(--gray-200); color: var(--navy-800); }
.modal-body { padding: 28px 36px 36px; }
.form-group { margin-bottom: 20px; }
.form-group label { display: block; font-size: 0.82rem; font-weight: 500; color: var(--navy-800); margin-bottom: 6px; }
.form-group .req { color: var(--purple-500); }
.form-group input, .form-group select, .form-group textarea { width: 100%; padding: 12px 16px; border: 1.5px solid var(--gray-200); border-radius: 10px; font-family: var(--font-body); font-size: 0.9rem; font-weight: 300; color: var(--gray-800); background: var(--white); transition: border-color 0.2s, box-shadow 0.2s; outline: none; }
.form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--purple-400); box-shadow: 0 0 0 3px rgba(107,63,160,0.08); }
.form-group input::placeholder, .form-group textarea::placeholder { color: var(--gray-300); }
.form-group textarea { resize: vertical; min-height: 100px; }
